FROM python:3.12-slim

RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    unixodbc \
    unixodbc-dev \
    curl \
    gnupg \
    apt-transport-https \
    ca-certificates \
    && curl -sSL https://packages.microsoft.com/keys/microsoft.asc \
    | gpg --dearmor > /usr/share/keyrings/microsoft-prod.gpg \
    && curl -sSL https://packages.microsoft.com/config/debian/12/prod.list \
    | sed 's|signed-by=|signed-by=/usr/share/keyrings/microsoft-prod.gpg signed-by=|' \
    > /etc/apt/sources.list.d/mssql-release.list \
    && apt-get update \
    && ACCEPT_EULA=Y apt-get install -y msodbcsql18 mssql-tools18 \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY pyproject.toml uv.lock /tmp/

RUN pip install uv && \
    cd /tmp && \
    uv sync --frozen --no-dev

ENV PATH="/tmp/.venv/bin:$PATH"

WORKDIR /opt/dagster/app

EXPOSE 4004

HEALTHCHECK --timeout=1s --start-period=3s --interval=3s --retries=20 \
    CMD ["dagster", "api", "grpc-health-check", "-p", "4004"]

CMD ["dagster", "code-server", "start", "-h", "0.0.0.0", "-p", "4004", "-f", "tedisc_dagster/definitions.py"]